---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title={`Blog - ${siteConfig.name}`}>
  <main class="max-w-4xl mx-auto px-6 py-20">
    <header class="mb-20 animate-fade-up">
      <a href="/" class="inline-flex items-center gap-2 text-accent font-bold mb-8 hover:translate-x-[-4px] transition-transform">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Home
      </a>
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 tracking-tight leading-tight">
        Technical Blog
      </h1>
      <p class="text-xl text-gray-600 font-medium max-w-2xl leading-relaxed">
        Insights on Computer Vision, Model Optimization, and Edge AI.
      </p>
    </header>

    <div class="grid gap-12">
      {posts.map((post) => (
        <article class="glass-card p-8 md:p-10 group hover:-translate-y-2 transition-all duration-300">
          <div class="flex justify-between items-start mb-6">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-[10px] font-bold text-accent uppercase tracking-wider bg-accent-soft px-2.5 py-1 rounded-md">
                  {tag}
                </span>
              ))}
            </div>
            <time datetime={post.data.pubDate.toISOString()} class="text-sm font-bold text-text-muted">
              {post.data.pubDate.toLocaleDateString('en-us', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
          <a href={`/blog/${post.slug}/`}>
            <h2 class="text-3xl font-bold mb-4 text-primary group-hover:text-accent transition-colors">
              {post.data.title}
            </h2>
          </a>
          <p class="text-text-muted text-lg leading-relaxed mb-8">
            {post.data.description}
          </p>
          <a href={`/blog/${post.slug}/`} class="inline-flex items-center gap-2 text-accent font-bold hover:translate-x-2 transition-transform">
            Read Post <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </article>
      ))}
    </div>

    <footer class="mt-40 pt-12 border-t border-gray-100 dark:border-slate-800 text-center text-text-muted text-sm">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}</p>
    </footer>
  </main>
</Layout>
